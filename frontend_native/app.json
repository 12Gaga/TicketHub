{
  "expo": {
    "name": "K Concert",
    "slug": "frontend_native",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/K-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#8B0000"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#8B0000"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.myat_noe.tickethub"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-font", "@react-native-community/datetimepicker"],
    "extra": {
      "eas": {
        "projectId": "6350b5b0-d0cc-4f2c-82a8-0c1a98acf753"
      }
    }
  }
}
